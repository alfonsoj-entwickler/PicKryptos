<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:id="@+id/activity_keys"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="@dimen/activity_vertical_margin"
    android:paddingLeft="@dimen/activity_horizontal_margin"
    android:paddingRight="@dimen/activity_horizontal_margin"
    android:paddingTop="@dimen/activity_vertical_margin"
    tools:context="com.example.quoson.pickryptos.KeysActivity">

    <ScrollView
        android:layout_width="fill_parent"
        android:layout_height="match_parent"
        android:id="@+id/scrollView">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="10dp">

            <Spinner
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:entries="@array/array_keys"
                android:id="@+id/select_algorithm"
                android:layout_marginBottom="10dip"
                android:hint="@string/menuConsole2"
                android:background="@drawable/border4"
                android:minHeight="45dip"
                android:padding="10dip"
                android:popupBackground="@drawable/border4"/>

            <Spinner
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:id="@+id/select_size"
                android:layout_marginBottom="10dip"
                android:hint="@string/menuConsole2"
                android:background="@drawable/border2"
                android:minHeight="45dip"
                android:padding="10dip"
                android:focusable="false"
                android:clickable="true"
                android:visibility="gone"/>

            <ImageButton
                android:layout_width="match_parent"
                android:layout_height="50dip"
                android:id="@+id/buttonCipher"
                android:src="@drawable/click_key"
                android:layout_weight="1"
                android:background="@drawable/border_off"
                android:layout_marginRight="25dip"
                android:layout_marginLeft="25dip"/>

            <EditText
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:id="@+id/editID"
                android:background="@drawable/border1"
                android:hint="@string/menuConsole7"
                android:drawablePadding="10dip"
                android:padding="10dip"
                android:textIsSelectable="false"
                android:textSize="20dip"
                android:minHeight="45dip"
                android:maxLength="8"
                android:layout_marginBottom="10dip"
                android:layout_marginTop="10dip"
                android:focusable="false"/>

            <ImageButton
                android:layout_width="match_parent"
                android:layout_height="50dip"
                android:id="@+id/buttonSave"
                android:background="@drawable/border_off"
                android:src="@drawable/click_save"
                android:layout_weight="1"
                android:layout_marginLeft="25dip"
                android:layout_marginRight="25dip"/>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/progressText"
                android:visibility="gone"
                android:focusable="false"
                android:layout_marginBottom="10dip"/>

            <EditText
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?android:attr/textAppearanceLarge"
                android:layout_gravity="left|top"
                android:id="@+id/resultText"
                android:background="@drawable/border3"
                android:shadowColor="#ff71ff7f"
                android:padding="10dip"
                android:inputType="textMultiLine"
                android:ems="10"
                android:ellipsize="middle"
                android:layout_marginBottom="10dip"
                android:scrollbars="vertical"
                android:gravity="top|left"
                android:textSize="20dip"
                android:minHeight="100dip"
                android:focusable="false"
                android:cursorVisible="true"
                android:layout_marginTop="10dip"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
